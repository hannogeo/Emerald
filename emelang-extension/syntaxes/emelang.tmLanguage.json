{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Emerald Language",
	"patterns": [
		{
			"include": "#comments"
		},
		{
			"include": "#variables"
		},
		{
			"include": "#keywords"
		},
		{
			"include": "#strings"
		},
		{
			"include": "#constants"
		}
	],
	"repository": {
		"comments": {
			"patterns": [
				{
					"name": "comment.line.double-slash.emelang",
					"match": "//.*$"
				}
			]
		},
		"keywords": {
			"patterns": [
				{
					"name": "keyword.control.emelang",
					"match": "\\b(if|elif|else|print|var|func)\\b"
				},
				{
					"name": "keyword.operator.comparison.emelang",
					"match": "!=|=<|=>|=|<|>"
				},
				{
					"name": "keyword.operator.arithmetic.emelang",
					"match": "\\+|\\-|\\*|/"
				}
			]
		},
		"strings": {
			"patterns": [
				{
					"name": "string.quoted.double.emelang",
					"begin": "\"",
					"end": "\"",
					"patterns": [
						{
							"name": "constant.character.escape.emelang",
							"match": "\\\\."
						}
					]
				},
				{
					"name": "string.quoted.single.emelang",
					"begin": "'",
					"end": "'",
					"patterns": [
						{
							"name": "constant.character.escape.emelang",
							"match": "\\\\."
						}
					]
				}
			]
		},
		"variables": {
			"patterns": [
				{
					"match": "\\b(var|func)\\.([A-Za-z_]\\w*)",
					"captures": {
						"2": {
							"name": "variable.name.emelang"
						}
					}
				},
				{
					"match": "\\b(var|func)\\s+([A-Za-z_]\\w*)",
					"captures": {
						"1": {
							"name": "keyword.control.emelang"
						},
						"2": {
							"name": "variable.name.emelang"
						}
					}
				}
			]
		},
		"constants": {
			"patterns": [
				{
					"name": "constant.language.boolean.emelang",
					"match": "\\b(True|False)\\b"
				},
				{
					"name": "constant.numeric.emelang",
					"match": "\\b\\d+(\\.\\d+)?\\b"
				}
			]
		}
	},
	"scopeName": "source.emelang"
}
