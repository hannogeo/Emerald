{
    "brackets": [
        ["(", ")"]
    ],
    "autoClosingPairs": [
        { "open": "(", "close": ")" },
        { "open": "\"", "close": "\"" },
        { "open": "'", "close": "'" }
    ],
    "surroundingPairs": [
        { "open": "(", "close": ")" },
        { "open": "\"", "close": "\"" },
        { "open": "'", "close": "'" }
    ],
    "comments": {
        "lineComment": "//"
    },
    "onEnterRules": [
        {
            "beforeText": "^\\s*(?:if|elif|else|func).*:\\s*$",
            "action": {
                "indent": "indent"
            }
        }
    ]
}
