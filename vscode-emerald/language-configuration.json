{
  "comments": {
    "lineComment": "!"
  },
  "brackets": [
    ["{", "}"]
  ],
  "autoClosingPairs": [
    {
      "open": "\"",
      "close": "\"",
      "notIn": ["string"]
    },
    {
      "open": "{",
      "close": "}"
    }
  ],
  "surroundingPairs": [
    ["\"", "\""],
    ["{", "}"]
  ],
  "indentationRules": {
    "increaseIndentPattern": "\\{[^}]*$",
    "decreaseIndentPattern": "^\\s*\\}"
  }
}
