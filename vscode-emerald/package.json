{
  "name": "emerald-lang",
  "displayName": "Emerald Language",
  "description": "Emerald language support - syntax highlighting for .emld files",
  "version": "0.1.7",
  "publisher": "emerald-lang",
  "icon": "emerald.png",
  "repository": { "url": "https://github.com/hannogeo/Emerald" },
  "license": "MIT",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "emerald",
        "aliases": ["Emerald", "emerald"],
        "extensions": [".emld"],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./emerald.svg",
          "dark": "./emerald.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "emerald",
        "scopeName": "source.emld",
        "path": "./syntaxes/emerald.tmLanguage.json"
      }
    ]
  }
}
